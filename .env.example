# Local development. Production values already live in /opt/lead-voice/config/*.env.
ELVIN_ENV=development
ELVIN_DOMAIN=localhost
ELVIN_BIND_HOST=127.0.0.1
ELVIN_BIND_PORT=8000
APP_SECRET_KEY=replace-with-long-random-value
CREDENTIALS_ENCRYPTION_KEY=replace-with-fernet-compatible-secret

# Leave database variables empty to use data/elvin-state.json locally.
ELVIN_DB_HOST=
ELVIN_DB_PORT=5432
ELVIN_DB_NAME=
ELVIN_DB_USER=
ELVIN_DB_PASSWORD=
ELVIN_DB_SSLMODE=require

ELVIN_LPTRACKER_BASE_URL=https://direct.lptracker.ru
GEMINI_API_KEY=
GEMINI_DIRECTOR_API_KEY=

# Real calls are disabled locally by default.
ELVIN_CALLS_ENABLED=false
ELVIN_MEDIA_READY=false
ELVIN_MEDIA_CONNECT_TIMEOUT_SECONDS=900

ELVIN_DATA_DIR=./data
ELVIN_LOG_DIR=./logs
ELVIN_RECORDINGS_DIR=./recordings
ELVIN_FRAME_TRACE_ENABLED=true
ELVIN_VAD_CONFIDENCE=0.45
ELVIN_VAD_START_SECONDS=0.08
ELVIN_VAD_STOP_SECONDS=0.20
ELVIN_VAD_MIN_VOLUME=0.03
ELVIN_PRE_ROLL_MS=240
ELVIN_SMART_TURN_RETRY_MS=200
ELVIN_TURN_MERGE_GRACE_MS=300
ELVIN_FORCE_END_SILENCE_MS=900
ELVIN_PCM_LEVEL_LOG_INTERVAL_SECONDS=1.0
